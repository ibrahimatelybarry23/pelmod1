% --------------------------------------------------------------------------
% AMBIENTE PROBLEMA
% --------------------------------------------------------------------------

\newcounter{problema}[chapter]
\renewcommand{\theproblema}{\thechapter.\arabic{problema}}

\newenvironment{problema}{%
    \refstepcounter{problema}%
    \begin{tcolorbox}[
        enhanced,                   % Obbligatorio per ombre
        colback=white,
        colframe=black,
        boxrule=0.4pt,
        arc=5mm,                    % Angoli stondati
        fuzzy shadow={0.4mm}{0.4mm}{0pt}{0pt}{black!50!white},  % Ombra personalizzata
        left=5mm, right=5mm,
        top=2mm, bottom=2mm,
        breakable
    ]%
    \noindent\textbf{Problema~\theproblema}\par\smallskip
}{%
    \end{tcolorbox}
}

